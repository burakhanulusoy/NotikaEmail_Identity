@{
    Layout = null;
}

<!DOCTYPE html>
<html class="dark" lang="tr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Notika Destek Sohbeti - @ViewBag.name</title>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#19e66b",
                        "primary-content": "#003816",
                        "primary-dark": "#10b050",
                        "primary-light": "#6ff0a2",
                        "background-light": "#f6f8f7",
                        "background-dark": "#112218",
                        "surface-dark": "#1a3324",
                        "surface-highlight": "#244732",
                        "text-main": "#ffffff",
                        "text-muted": "#93c8a8",
                    },
                    fontFamily: {
                        "display": ["Manrope", "sans-serif"]
                    },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        ::-webkit-scrollbar {
            width: 8px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: #244732;
            border-radius: 4px;
        }

            ::-webkit-scrollbar-thumb:hover {
                background: #19e66b;
            }
    </style>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-text-main overflow-hidden h-screen flex">

    <aside class="w-80 flex-shrink-0 flex flex-col border-r border-surface-highlight bg-background-dark h-full">
        <div class="p-6 pb-4">
            <div class="flex items-center gap-3 mb-6">
                <div class="bg-center bg-no-repeat bg-cover rounded-full h-10 w-10 ring-2 ring-primary/20 bg-surface-highlight flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary">support_agent</span>
                </div>
                <div class="flex flex-col">
                    <h1 class="text-white text-base font-bold leading-tight">Notika Destek</h1>
                    <div class="flex items-center gap-1.5">
                        <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
                        <p class="text-text-muted text-xs font-medium uppercase tracking-wide">Çevrimiçi</p>
                    </div>
                </div>
            </div>
            <nav class="flex flex-col gap-1">
                <a class="flex items-center gap-3 px-3 py-2 rounded-lg bg-surface-highlight text-white group transition-colors" href="#">
                    <span class="material-symbols-outlined text-primary">inbox</span>
                    <span class="text-sm font-medium flex-1">Gelen Kutusu</span>
                    <span class="bg-primary text-primary-content text-xs font-bold px-2 py-0.5 rounded-full">3</span>
                </a>
                <a class="flex items-center gap-3 px-3 py-2 rounded-lg text-text-muted hover:bg-surface-highlight/50 hover:text-white transition-colors" href="#">
                    <span class="material-symbols-outlined">settings</span>
                    <span class="text-sm font-medium">Ayarlar</span>
                </a>
            </nav>
        </div>

        <div class="flex-1 overflow-y-auto px-4 pb-4 space-y-1">
            <h3 class="px-2 py-2 text-xs font-semibold text-text-muted uppercase tracking-wider">Son Sohbetler</h3>
            <div class="flex items-start gap-3 p-3 rounded-lg bg-surface-highlight/50 border border-surface-highlight cursor-pointer transition-colors relative">
                <div class="relative flex-shrink-0">
                    <div class="bg-center bg-no-repeat bg-cover rounded-full h-10 w-10" style='background-image: url("@ViewBag.imageUrl");'></div>
                    <span class="absolute bottom-0 right-0 w-3 h-3 bg-green-500 border-2 border-surface-highlight rounded-full"></span>
                </div>
                <div class="flex-1 min-w-0">
                    <div class="flex justify-between items-baseline mb-0.5">
                        <h4 class="text-sm font-semibold text-white truncate">@ViewBag.name</h4>
                        <span class="text-xs text-primary font-medium">Şimdi</span>
                    </div>
                    <p class="text-sm text-text-muted truncate">Aktif Destek Talebi</p>
                </div>
            </div>
        </div>
    </aside>

    <main class="flex-1 flex flex-col h-full bg-surface-dark relative">
        <header class="flex-shrink-0 h-16 border-b border-surface-highlight bg-background-dark/95 backdrop-blur flex items-center justify-between px-6 z-10">
            <div class="flex items-center gap-4">
                <div class="relative">
                    <div class="bg-center bg-no-repeat bg-cover rounded-full h-10 w-10" style='background-image: url("@ViewBag.imageUrl");'></div>
                    <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-500 border-2 border-background-dark rounded-full"></span>
                </div>
                <div>
                    <h2 class="text-white font-bold text-lg leading-tight">@ViewBag.name</h2>
                    <p class="text-text-muted text-xs flex items-center gap-1">
                        <span class="w-1.5 h-1.5 bg-primary/70 rounded-full"></span>
                        Şu an aktif
                    </p>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <button class="p-2 text-text-muted hover:text-white hover:bg-surface-highlight rounded-full transition-colors"><span class="material-symbols-outlined">more_vert</span></button>
            </div>
        </header>

        <div id="chatMessages" class="flex-1 overflow-y-auto p-6 space-y-6 flex flex-col scroll-smooth">
            <div class="flex justify-center">
                <span class="px-3 py-1 bg-surface-highlight/40 rounded-full text-xs text-text-muted font-medium">Bugün</span>
            </div>

            <div class="flex flex-row-reverse items-end gap-3 self-end max-w-[80%]">
                <div class="bg-surface-highlight flex items-center justify-center rounded-full h-8 w-8 flex-shrink-0 mb-1">
                    <span class="material-symbols-outlined text-primary text-sm">support_agent</span>
                </div>
                <div class="flex flex-col items-end gap-1">
                    <div class="bg-primary text-primary-content p-4 rounded-2xl rounded-tr-sm shadow-sm">
                        <p class="text-sm font-medium leading-relaxed">Merhaba @ViewBag.name! Notika Destek'e ulaştığınız için teşekkürler. Size nasıl destek olabilirim?</p>
                    </div>
                    <span class="text-[10px] text-text-muted/60 font-medium mr-1">@DateTime.Now.ToString("HH:mm")</span>
                </div>
            </div>

            <div id="typingIndicator" class="hidden flex items-end gap-3 self-end max-w-[80%] opacity-80">
                <div class="bg-surface-highlight flex items-center justify-center rounded-full h-8 w-8 flex-shrink-0 mb-1">
                    <span class="material-symbols-outlined text-primary text-sm">support_agent</span>
                </div>
                <div class="bg-surface-highlight/30 p-3 rounded-2xl rounded-tr-sm">
                    <div class="flex gap-1">
                        <span class="w-2 h-2 bg-primary rounded-full animate-bounce"></span>
                        <span class="w-2 h-2 bg-primary rounded-full animate-bounce" style="animation-delay: 0.2s"></span>
                        <span class="w-2 h-2 bg-primary rounded-full animate-bounce" style="animation-delay: 0.4s"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex-shrink-0 p-6 pt-2 bg-surface-dark">
            <div class="bg-surface-highlight/50 rounded-xl p-2 border border-surface-highlight flex flex-col gap-2 focus-within:ring-1 focus-within:ring-primary/50 transition-all shadow-lg">
                <textarea id="chatInput" class="w-full bg-transparent border-none text-white placeholder-text-muted resize-none focus:ring-0 text-sm p-3" placeholder="Mesajınızı yazın..." rows="2"></textarea>
                <div class="flex justify-between items-center px-2 pb-1">
                    <div class="flex gap-1 text-text-muted">
                        <button class="p-2 hover:bg-surface-highlight rounded-lg transition-colors hover:text-primary tooltip"><span class="material-symbols-outlined text-[20px]">attach_file</span></button>
                    </div>
                    <button id="sendBtn" class="bg-primary hover:bg-primary-dark text-primary-content font-bold py-2 px-4 rounded-lg flex items-center gap-2 transition-colors text-sm shadow-md shadow-primary/10">
                        <span>Gönder</span>
                        <span class="material-symbols-outlined text-[18px]">send</span>
                    </button>
                </div>
            </div>
        </div>
    </main>

    <aside class="w-72 border-l border-surface-highlight bg-background-dark hidden xl:flex flex-col overflow-y-auto">
        <div class="p-6">
            <h3 class="text-sm font-bold text-white mb-4 uppercase tracking-wide">Müşteri Detayları</h3>
            <div class="flex flex-col items-center mb-6">
                <div class="bg-center bg-no-repeat bg-cover rounded-full h-20 w-20 mb-3 ring-4 ring-surface-highlight" style='background-image: url("@ViewBag.imageUrl");'></div>
                <h2 class="text-lg font-bold text-white text-center">@ViewBag.name</h2>
                <p class="text-text-muted text-sm text-center">@ViewBag.email</p>
            </div>
            <div class="space-y-4">
                <div class="bg-surface-highlight/30 p-4 rounded-lg border border-surface-highlight/50">
                    <p class="text-xs text-text-muted uppercase font-bold mb-1">Hesap Oluşturma</p>
                    <p class="text-sm text-white font-medium">@ViewBag.createdDate</p>
                </div>
                <div class="bg-surface-highlight/30 p-4 rounded-lg border border-surface-highlight/50">
                    <p class="text-xs text-text-muted uppercase font-bold mb-1">Mevcut Plan</p>
                    <div class="flex justify-between items-center">
                        <p class="text-sm text-white font-medium">Standart Üye</p>
                        <span class="text-xs bg-primary/20 text-primary px-2 py-0.5 rounded font-bold">AKTİF</span>
                    </div>
                </div>
                <div class="bg-surface-highlight/30 p-4 rounded-lg border border-surface-highlight/50">
                    <p class="text-xs text-text-muted uppercase font-bold mb-1">Son Etkileşim</p>
                    <p class="text-sm text-white font-medium">@ViewBag.lastDateSend</p>
                </div>
            </div>
        </div>
    </aside>

    <script>
        const chatMessages = document.getElementById('chatMessages');
        const chatInput = document.getElementById('chatInput');
        const sendBtn = document.getElementById('sendBtn');
        const typingIndicator = document.getElementById('typingIndicator');

        // 🌟 CLAUDE'DAN GELEN YANITLARI HARİKA GÖSTEREN FORMATLAYICI (MARKDOWN PARSER)
        function formatClaudeResponse(text) {
            if (!text) return '';
            let html = text
                // 1. Kalın yazılar (Örn: **Adım 1:**)
                .replace(/\*\*(.*?)\*\*/g, '<strong class="font-bold text-white">$1</strong>')
                // 2. İtalik yazılar (Örn: *Not:*)
                .replace(/\*(.*?)\*/g, '<em class="italic text-white/90">$1</em>')
                // 3. Madde İşaretleri (- veya * ile başlayanlar) Tailwind UI ile süslendi
                .replace(/^\s*[\-\*]\s+(.*)$/gm, '<div class="flex items-start gap-2 mt-2"><span class="w-1.5 h-1.5 rounded-full bg-primary-content flex-shrink-0 mt-1.5 opacity-80"></span><span class="flex-1">$1</span></div>')
                // 4. Numaralı Listeler (1. 2. ile başlayanlar)
                .replace(/^\s*(\d+)\.\s+(.*)$/gm, '<div class="flex items-start gap-2 mt-2"><span class="text-primary-content font-bold w-4">$1.</span><span class="flex-1">$2</span></div>')
                // 5. Normal alt satıra geçişleri <br> yap (Madde işaretlerinden sonra çoklu boşluk olmasını engeller)
                .replace(/\n/g, '<br>');

            // Oluşan gereksiz fazla boşlukları (br) temizle
            html = html.replace(/(<br>\s*){2,}/g, '<br><br>');
            // Div (madde işareti) içindeki <br> leri temizle
            html = html.replace(/<\/div><br>/g, '</div>');

            return html;
        }

        function appendMessage(message, isUser) {
            const time = new Date().toLocaleTimeString('tr-TR', { hour: '2-digit', minute: '2-digit' });

            let messageHtml = '';
            if (isUser) {
                // Kullanıcı Mesajı (ViewBag ile kendi resmi)
                messageHtml = `
                <div class="flex items-end gap-3 self-start max-w-[80%]">
                    <div class="bg-center bg-no-repeat bg-cover rounded-full h-8 w-8 flex-shrink-0 mb-1" style='background-image: url("@ViewBag.imageUrl");'></div>
                    <div class="flex flex-col items-start gap-1">
                        <div class="bg-surface-highlight p-4 rounded-2xl rounded-tl-sm text-white shadow-sm border border-white/5">
                            <p class="text-sm leading-relaxed">${message}</p>
                        </div>
                        <span class="text-[10px] text-text-muted/60 font-medium ml-1">${time}</span>
                    </div>
                </div>`;
            } else {
                // Claude Mesajı (Formatlanmış Haliyle)
                messageHtml = `
                <div class="flex flex-row-reverse items-end gap-3 self-end max-w-[80%]">
                    <div class="bg-surface-highlight flex items-center justify-center rounded-full h-8 w-8 flex-shrink-0 mb-1">
                        <span class="material-symbols-outlined text-primary text-sm">support_agent</span>
                    </div>
                    <div class="flex flex-col items-end gap-1 w-full">
                        <div class="bg-primary text-primary-content p-4 rounded-2xl rounded-tr-sm shadow-sm w-full">
                            <div class="text-sm font-medium leading-relaxed">${formatClaudeResponse(message)}</div>
                        </div>
                        <div class="flex items-center gap-1 mt-0.5">
                            <span class="material-symbols-outlined text-primary text-[14px]">done_all</span>
                            <span class="text-[10px] text-text-muted/60 font-medium">${time}</span>
                        </div>
                    </div>
                </div>`;
            }

            if (!typingIndicator.classList.contains('hidden')) {
                chatMessages.insertBefore(document.createRange().createContextualFragment(messageHtml), typingIndicator);
            } else {
                chatMessages.insertAdjacentHTML('beforeend', messageHtml);
            }
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        async function sendMessage() {
            const text = chatInput.value.trim();
            if (!text) return;

            appendMessage(text, true);
            chatInput.value = '';

            typingIndicator.classList.remove('hidden');
            chatMessages.scrollTop = chatMessages.scrollHeight;

            try {
                const response = await fetch('/CloudeAi/AskClaude', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ prompt: text })
                });

                const result = await response.json();
                typingIndicator.classList.add('hidden');

                if (response.ok) {
                    appendMessage(result.answer, false);
                } else {
                    appendMessage("Sistem Mesajı: " + result.answer, false);
                }
            } catch (error) {
                typingIndicator.classList.add('hidden');
                appendMessage("Ciddi bir bağlantı hatası oluştu veya sunucuya ulaşılamıyor.", false);
            }
        }

        sendBtn.addEventListener('click', sendMessage);

        chatInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });
    </script>
</body>
</html>