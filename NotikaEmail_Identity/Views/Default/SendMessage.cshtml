@model SendMessageViewModel

@{
    ViewData["Title"] = "SendMessage";
    Layout = "~/Views/WebUI/Index.cshtml";
}

<style>
    /* Genel Kart Tasarımı */
    .email-card {
        border-radius: 12px;
        border: none;
        background: #fff;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        padding: 30px;
    }

    .email-card-header {
        border-bottom: 1px solid #f0f0f0;
        margin-bottom: 25px;
        padding-bottom: 15px;
    }

        .email-card-header h2 {
            margin: 0;
            color: #2c3e50;
            font-size: 22px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
        }

    /* Modern Input Alanları */
    .form-group label {
        font-weight: 500;
        color: #6c757d;
        margin-bottom: 8px;
        display: block;
        font-size: 14px;
    }

    .modern-input {
        border: 1px solid #e0e4e8;
        border-radius: 8px;
        padding: 12px 15px;
        box-shadow: none;
        transition: all 0.3s ease;
        background-color: #f8f9fa;
        width: 100%;
        color: #333;
    }

        .modern-input:focus {
            border-color: #667eea;
            background-color: #fff;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.15);
            outline: none;
        }

    .custom-select {
        height: 48px;
        cursor: pointer;
    }

    /* Gmail Tarzı Dosya Ekleme Alanı */
    .attachment-section {
        display: flex;
        align-items: center;
        gap: 15px;
        padding-top: 15px;
        border-top: 1px solid #f0f0f0;
        margin-top: 10px;
    }

    .attachment-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background-color: transparent;
        color: #5f6368;
        cursor: pointer;
        transition: background-color 0.2s;
        margin: 0;
    }

        .attachment-btn:hover {
            background-color: #f1f3f4;
            color: #202124;
        }

    /* Seçilen Dosya İsmi Baloncuğu */
    .file-name-badge {
        display: none; /* Dosya seçilene kadar gizli */
        align-items: center;
        gap: 8px;
        background: #f1f3f4;
        color: #3c4043;
        padding: 6px 14px;
        border-radius: 16px;
        font-size: 13px;
        font-weight: 500;
        border: 1px solid #e8eaed;
    }

    /* BUTON GRUBU TASARIMI */

    /* Ortak Buton Özellikleri */
    .btn-action {
        border-radius: 50px; /* Tam oval (Pill) görünüm */
        padding: 12px 35px;
        font-weight: 600;
        font-size: 14px;
        letter-spacing: 0.5px;
        border: none;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        position: relative;
        overflow: hidden;
    }

    /* Vazgeç Butonu (Sakin ve Modern) */
    .btn-cancel-modern {
        background-color: #f8f9fa;
        color: #7f8c8d;
        border: 1px solid #e0e4e8;
    }

        .btn-cancel-modern:hover {
            background-color: #fff5f5;
            color: #e74c3c; /* Üzerine gelince kırmızılaşır */
            border-color: #ffcccc;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(231, 76, 60, 0.15);
        }

    /* Gönder Butonu (Canlı ve Dikkat Çekici) */
    .btn-send-modern {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); /* Mor-Mavi Geçiş */
        color: white;
        box-shadow: 0 4px 15px rgba(118, 75, 162, 0.3);
    }

        .btn-send-modern:hover {
            background: linear-gradient(135deg, #764ba2 0%, #667eea 100%); /* Rengi ters çevir */
            color: white;
            transform: translateY(-2px); /* Hafif yukarı kalkma efekti */
            box-shadow: 0 8px 25px rgba(118, 75, 162, 0.5); /* Gölgeyi büyüt */
        }

        .btn-send-modern i, .btn-cancel-modern i {
            font-size: 16px; /* İkon boyutunu ayarla */
        }
</style>

<div class="inbox-area">
    <div class="container">
        <div class="row">

            @await Component.InvokeAsync("_MessageMenuSidebarComponentPartial")

            <div class="col-lg-9 col-md-9 col-sm-8 col-xs-12">
                <div class="email-card sm-res-mg-t-30">

                    <div class="email-card-header">
                        <h2><i class="notika-icon notika-edit"></i> Yeni Mesaj Gönder</h2>
                    </div>

                    <div class="email-card-body">
                        <form method="post" enctype="multipart/form-data" id="messageForm">

                            <div class="row">
                                <div class="col-lg-6 col-md-6 col-sm-12">
                                    <div class="form-group">
                                        <label>Alıcı E-posta Adresi</label>
                                        <input type="email" asp-for="ReceiverEmail" class="form-control modern-input" name="ReceiverEmail" placeholder="ornek@email.com" required />
                                    </div>
                                </div>
                            </div>

                            <div class="row mt-3">
                                <div class="col-lg-6 col-md-6 col-sm-12">
                                    <div class="form-group">
                                        <label>Kategori</label>
                                        <select asp-for="MessageCategoryId" asp-items="@ViewBag.categories" class="form-control modern-input custom-select" required>
                                            <option value="" selected disabled>Kategori Seçiniz...</option>
                                        </select>
                                    </div>
                                </div>

                                <div class="col-lg-6 col-md-6 col-sm-12">
                                    <div class="form-group">
                                        <label>Konu</label>
                                        <input type="text" class="form-control modern-input" asp-for="Subject" placeholder="Mesajınızın konusu" required />
                                    </div>
                                </div>
                            </div>

                            <div class="row mt-3">
                                <div class="col-lg-12">
                                    <div class="form-group">
                                        <label>Mesajınız</label>
                                        <textarea class="form-control modern-input" asp-for="MessageDetail" rows="8" placeholder="Mesajınızı buraya yazın..." required></textarea>
                                    </div>
                                </div>
                            </div>

                            <div class="attachment-section d-flex justify-content-between align-items-center mt-4">

                                <div class="d-flex align-items-center">
                                    <label for="file-upload" class="attachment-btn" title="Dosya Ekle">
                                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path>
                                        </svg>
                                    </label>
                                    <input id="file-upload" type="file" name="AttachedFile" style="display: none;" onchange="showFileName(this)" />

                                    <span id="file-name-display" class="file-name-badge">
                                        <i class="notika-icon notika-file"></i> <span id="file-name-text"></span>
                                    </span>
                                </div>

                                <div class="d-flex" style="gap: 15px;">

                                    <button type="button" id="btnCancel" class="btn-action btn-cancel-modern">
                                        <i class="notika-icon notika-close"></i> Vazgeç
                                    </button>

                                    <button id="messageForm" type="submit" class="btn-action btn-send-modern">
                                        Mesajı Gönder <i class="notika-icon notika-right-arrow"></i>
                                    </button>

                                </div>

                            </div>

                            <span class="text-danger d-block mt-2">@Html.ValidationSummary()</span>

                        </form>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<script>
    function showFileName(input) {
        const displayBadge = document.getElementById('file-name-display');
        const textSpan = document.getElementById('file-name-text');

        if (input.files && input.files.length > 0) {
            textSpan.textContent = input.files[0].name;
            displayBadge.style.display = 'inline-flex';
        } else {
            displayBadge.style.display = 'none';
        }
    }
</script>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    $(document).ready(function () {

        // ---------------------------------------------------------
        // 1. SENARYO: "GÖNDER" BUTONUNA BASILINCA (Zorunlu Alan Kontrolü)
        // ---------------------------------------------------------
        $('#messageForm').on('submit', function (e) {

            // Değerleri alıyoruz
            var receiver = $('[name="ReceiverEmail"]').val().trim();
            var subject = $('[name="Subject"]').val().trim();
            var category = $('[name="MessageCategoryId"]').val();
            var message = $('[name="MessageDetail"]').val().trim();

            // KONTROL: Eğer bunlardan biri boşsa
            // Not: category bazen null döner, bazen boş string "" döner, ikisini de kontrol edelim.
            if (receiver === "" || subject === "" || category === null || category === "") {

                e.preventDefault(); // Dur! Gönderme.

                Swal.fire({
                    icon: 'error',
                    title: 'Eksik Bilgi!',
                    text: 'Lütfen Alıcı E-posta, Kategori ve Konu alanlarını mutlaka doldurunuz.',
                    confirmButtonColor: '#d33',
                    confirmButtonText: 'Tamam'
                });
            }
            // Else durumuna gerek yok, hata yoksa form kendiliğinden gider.
        });


        // ---------------------------------------------------------
        // 2. SENARYO: "VAZGEÇ" BUTONUNA BASILINCA (Taslak Kaydetme)
        // ---------------------------------------------------------
        $('#btnCancel').on('click', function (e) {
            e.preventDefault();

            var receiver = $('[name="ReceiverEmail"]').val();
            var subject = $('[name="Subject"]').val();
            var content = $('[name="MessageDetail"]').val();

            // Eğer herhangi bir alan doluysa sor
            if (receiver !== "" || subject !== "" || content !== "") {
                Swal.fire({
                    title: 'Sayfadan ayrılıyorsunuz!',
                    text: "Yazdıklarınızı taslak olarak kaydetmek ister misiniz?",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#00c292',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Evet, Taslaklara Kaydet',
                    cancelButtonText: 'İptal, Sayfada Kal'
                }).then((result) => {
                    if (result.isConfirmed) {

                        var formElement = document.getElementById('messageForm');
                        var formData = new FormData(formElement);

                        $.ajax({
                            url: '/Default/SaveDraftMessage',
                            type: 'POST',
                            data: formData,
                            processData: false,
                            contentType: false,
                            success: function (response) {
                                if (response.success) {
                                    Swal.fire('Kaydedildi!', 'Mesajınız taslaklara eklendi.', 'success')
                                        .then(() => {
                                            window.location.href = '/Default/Inbox';
                                        });
                                }
                            },
                            error: function () {
                                Swal.fire('Hata!', 'Taslak kaydedilirken bir sorun oluştu.', 'error');
                            }
                        });
                    }
                });
            } else {
                // Form boşsa direkt çık
                window.location.href = '/Default/Inbox';
            }
        });

    });
</script>





