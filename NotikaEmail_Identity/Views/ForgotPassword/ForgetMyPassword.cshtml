@model ForgetPasswordViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#13ec5b",
                        "background-light": "#f6f8f6",
                        "background-dark": "#102216",
                    },
                    fontFamily: {
                        "display": ["Inter", "sans-serif"]
                    },
                    borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"},
                },
            },
        }
    </script>
    <title>Notika - Şifremi Unuttum</title>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100 antialiased">
    <div class="relative flex h-auto min-h-screen w-full flex-col group/design-root overflow-x-hidden">
        <div class="layout-container flex h-full grow flex-col">
            <header class="flex items-center justify-between whitespace-nowrap border-b border-solid border-primary/10 px-6 py-4 lg:px-40 bg-background-light/80 backdrop-blur-md sticky top-0 z-50 dark:bg-background-dark/80">
                <div class="flex items-center gap-3 text-slate-900 dark:text-slate-100">
                    <div class="size-8 flex items-center justify-center bg-primary rounded-lg text-background-dark">
                        <span class="material-symbols-outlined text-2xl font-bold">diamond</span>
                    </div>
                    <h2 class="text-xl font-bold leading-tight tracking-tight">Notika</h2>
                </div>
                <div class="flex items-center gap-2">
                    <a href="/Login/SignIn" class="text-sm font-semibold hover:text-primary transition-colors flex items-center gap-1">
                        <span class="material-symbols-outlined text-lg">arrow_back</span>
                        Girişe Dön
                    </a>
                </div>
            </header>

            <div class="flex flex-1 justify-center py-12 px-6 lg:px-40">
                <div class="layout-content-container flex flex-col max-w-[480px] w-full flex-1 space-y-8">

                    @* EĞER MAİL GÖNDERİLDİYSE BU EKRAN ÇIKACAK *@
                    @if (ViewBag.SuccessMessage != null)
                    {
                        <div class="flex flex-col items-center justify-center text-center space-y-6 mt-10">
                            <div class="size-24 bg-primary/20 rounded-full flex items-center justify-center animate-pulse">
                                <span class="material-symbols-outlined text-6xl text-primary">mark_email_read</span>
                            </div>
                            <h1 class="text-3xl font-black leading-tight tracking-tight text-slate-900 dark:text-slate-100">
                                E-postanızı Kontrol Edin
                            </h1>
                            <p class="text-slate-600 dark:text-slate-400 text-lg">
                                Şifre sıfırlama bağlantınızı gönderdik. Lütfen gelen kutunuzu (veya spam klasörünü) kontrol edip maildeki linke tıklayarak yeni şifrenizi belirleyin.
                            </p>
                        </div>
                    }
                    @* EĞER MAİL HENÜZ GÖNDERİLMEDİYSE FORM EKRANI ÇIKACAK *@
                    else
                    {
                        <div class="flex flex-col gap-4 text-center lg:text-left">
                            <h1 class="text-slate-900 dark:text-slate-100 text-4xl font-black leading-tight tracking-tight">Şifrenizi Mi Unuttunuz?</h1>
                            <p class="text-slate-600 dark:text-slate-400 text-lg font-normal leading-relaxed">
                                Endişelenmeyin! Sisteme kayıtlı e-posta adresinizi girin, size şifrenizi sıfırlamanız için bir bağlantı gönderelim.
                            </p>
                        </div>

                        <form method="post">
                            <div class="flex justify-center lg:justify-start py-6 w-full">
                                <div class="relative w-full">
                                    <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none text-slate-400">
                                        <span class="material-symbols-outlined">mail</span>
                                    </div>
                                    <input required class="w-full h-16 pl-12 pr-4 bg-white dark:bg-slate-800 rounded-xl border-2 border-slate-200 dark:border-slate-700 focus:border-primary focus:ring-0 transition-all outline-none text-lg placeholder:text-slate-400 text-slate-900 dark:text-white font-medium" placeholder="E-posta adresiniz..." type="email" asp-for="Email" />
                                </div>
                            </div>

                            @* Hata mesajlarını göstermek için *@
                            <div class="text-red-500 font-semibold mb-4 text-center">
                                @Html.ValidationSummary(true)
                            </div>

                            <div class="flex flex-col gap-4">
                                <button type="submit" class="flex w-full cursor-pointer items-center justify-center overflow-hidden rounded-xl h-14 px-5 bg-primary text-slate-900 text-lg font-bold leading-normal tracking-wide shadow-lg shadow-primary/20 hover:scale-[1.02] transition-transform">
                                    <span class="truncate">Sıfırlama Linki Gönder</span>
                                </button>

                                <div class="flex flex-col items-center gap-4 mt-2">
                                    <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400 text-sm">
                                        <span class="material-symbols-outlined text-base">shield_lock</span>
                                        <p>Şifreleme altyapısı ile güvendesiniz</p>
                                    </div>
                                </div>
                            </div>
                        </form>
                    }
                </div>
            </div>

            <div class="fixed bottom-0 right-0 p-10 pointer-events-none opacity-10 dark:opacity-5">
                <span class="material-symbols-outlined text-[300px] text-primary">security</span>
            </div>
        </div>
    </div>
</body>
</html>