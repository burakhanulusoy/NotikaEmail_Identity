@model ResetPasswordViewModel

@{
    Layout = null;
}
<!DOCTYPE html>

<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#13ec5b",
                        "background-light": "#f6f8f6",
                        "background-dark": "#102216",
                    },
                    fontFamily: {
                        "display": ["Inter"]
                    },
                    borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"},
                },
            },
        }
    </script>
    <title>Notika - Şifre Belirleyin</title>
</head>
<body class="bg-background-light dark:bg-background-dark font-display text-slate-900 dark:text-slate-100">
    <div class="relative flex h-auto min-h-screen w-full flex-col group/design-root overflow-x-hidden">
        <div class="layout-container flex h-full grow flex-col">
            <div class="px-4 md:px-20 lg:px-40 flex flex-1 justify-center py-5">
                <div class="layout-content-container flex flex-col max-w-[480px] flex-1">
                    <header class="flex items-center justify-between whitespace-nowrap border-b border-solid border-primary/10 px-4 py-3">
                        <div class="flex items-center gap-4 text-slate-900 dark:text-slate-100">
                            <div class="size-6 text-primary">
                                <svg fill="none" viewbox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                                    <g clip-path="url(#clip0_6_330)">
                                        <path clip-rule="evenodd" d="M24 0.757355L47.2426 24L24 47.2426L0.757355 24L24 0.757355ZM21 35.7574V12.2426L9.24264 24L21 35.7574Z" fill="currentColor" fill-rule="evenodd"></path>
                                    </g>
                                    <defs>
                                        <clippath id="clip0_6_330"><rect fill="white" height="48" width="48"></rect></clippath>
                                    </defs>
                                </svg>
                            </div>
                            <h2 class="text-lg font-bold leading-tight tracking-tight">Notika</h2>
                        </div>
                    </header>

                    @* EĞER ŞİFRE DEĞİŞİMİ BAŞARILIYSA BU EKRAN ÇIKACAK *@
                    @if (ViewBag.SuccessMessage != null)
                    {
                        <div class="flex flex-col items-center justify-center text-center space-y-6 mt-16">
                            <div class="size-24 bg-primary/10 rounded-full flex items-center justify-center">
                                <span class="material-symbols-outlined text-6xl text-primary animate-spin">autorenew</span>
                            </div>

                            <h1 class="text-3xl font-black leading-tight tracking-tight text-slate-900 dark:text-slate-100">
                                Sistem Güncelleniyor...
                            </h1>
                            <p class="text-slate-600 dark:text-slate-400 text-lg font-medium animate-pulse">
                                Şifreniz başarıyla değiştirildi. Giriş sayfasına yönlendiriliyorsunuz, lütfen bekleyin.
                            </p>
                        </div>

                        <script>
                            setTimeout(function () {
                                window.location.href = '/Login/SignIn';
                            }, 5000); // 5000 milisaniye = 5 Saniye
                        </script>
                    }
                    @* EĞER ŞİFRE HENÜZ DEĞİŞMEDİYSE FORM EKRANI ÇIKACAK *@
                    else
                    {
                        <form method="post">
                            <div class="mt-8 mb-6 flex flex-col items-center">
                                <div class="w-24 h-24 bg-primary/10 rounded-full flex items-center justify-center mb-6">
                                    <span class="material-symbols-outlined text-5xl text-primary">password</span>
                                </div>
                                <div class="w-full text-center px-4">
                                    <h1 class="text-slate-900 dark:text-slate-100 text-3xl font-bold leading-tight mb-2">Şifre Belirleyin</h1>
                                    <p class="text-slate-500 dark:text-slate-400 text-sm font-normal leading-normal">Hesabınız için yeni ve güvenli bir şifre oluşturun.</p>
                                </div>
                            </div>

                            <div class="flex flex-col gap-5 px-4">
                                @* Hata mesajlarını göstermek için (Kırmızı renkte uyarı) *@
                                <div class="text-red-500 font-semibold text-center text-sm">
                                    @Html.ValidationSummary(true)
                                </div>

                                <label class="flex flex-col gap-2">
                                    <p class="text-slate-700 dark:text-slate-300 text-sm font-semibold leading-normal">Yeni Şifre</p>
                                    <div class="flex w-full items-stretch rounded-lg group">
                                        <input asp-for="Password" class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-l-lg text-slate-900 dark:text-slate-100 focus:outline-0 focus:ring-1 focus:ring-primary border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 h-14 placeholder:text-slate-400 p-[15px] border-r-0 text-base font-normal leading-normal" placeholder="********" type="password" />
                                        <div class="text-slate-400 flex border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 items-center justify-center pr-[15px] rounded-r-lg border-l-0 cursor-pointer hover:text-primary transition-colors">
                                            <span class="material-symbols-outlined">visibility</span>
                                        </div>
                                    </div>
                                    <span class="text-red-500 text-xs" asp-validation-for="Password"></span>
                                </label>

                                <label class="flex flex-col gap-2">
                                    <p class="text-slate-700 dark:text-slate-300 text-sm font-semibold leading-normal">Şifre Tekrarı</p>
                                    <div class="flex w-full items-stretch rounded-lg group">
                                        <input asp-for="ConfirmPassword" class="form-input flex w-full min-w-0 flex-1 resize-none overflow-hidden rounded-l-lg text-slate-900 dark:text-slate-100 focus:outline-0 focus:ring-1 focus:ring-primary border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 h-14 placeholder:text-slate-400 p-[15px] border-r-0 text-base font-normal leading-normal" placeholder="********" type="password" />
                                        <div class="text-slate-400 flex border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 items-center justify-center pr-[15px] rounded-r-lg border-l-0 cursor-pointer hover:text-primary transition-colors">
                                            <span class="material-symbols-outlined">visibility</span>
                                        </div>
                                    </div>
                                    <span class="text-red-500 text-xs" asp-validation-for="ConfirmPassword"></span>
                                </label>

                                <div class="mt-4">
                                    <button type="submit" class="w-full bg-primary hover:bg-primary/90 text-slate-950 font-bold py-4 px-6 rounded-xl transition-all shadow-lg shadow-primary/20 active:scale-[0.98]">
                                        Şifremi Güncelle
                                    </button>
                                </div>
                            </div>
                        </form>
                    }

                    <footer class="mt-auto py-10 text-center">
                        <p class="text-slate-400 text-xs">© 2024 Notika. Tüm hakları saklıdır.</p>
                    </footer>
                </div>
            </div>
        </div>
    </div>
</body>
</html>