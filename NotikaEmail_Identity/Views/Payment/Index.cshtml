@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notika - Güvenli Ödeme</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f6f8f6; /* Notika arka plan rengi */
            color: #0d1b12;
            min-height: 100vh;
            display: flex;
            align-items: center;
        }

        .payment-card {
            background: #ffffff;
            border-radius: 1.5rem;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.05);
            border: 1px solid rgba(0, 0, 0, 0.05);
            overflow: hidden;
        }

        .payment-header {
            background: linear-gradient(135deg, #102216 0%, #1a2f23 100%);
            color: white;
            padding: 2rem 1.5rem;
            text-align: center;
        }

        .form-label {
            font-size: 0.85rem;
            font-weight: 600;
            color: #6c757d;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 0.4rem;
        }

        .custom-input {
            background-color: #f8f9fa;
            border: 1px solid #e9ecef;
            border-radius: 0.75rem;
            padding: 0.75rem 1rem;
            font-size: 1rem;
            transition: all 0.2s ease-in-out;
        }

            .custom-input:focus {
                background-color: #ffffff;
                border-color: #13ec5b;
                box-shadow: 0 0 0 4px rgba(19, 236, 91, 0.15);
                outline: none;
            }

        .btn-notika-primary {
            background-color: #13ec5b;
            color: #0d1b12;
            font-weight: 700;
            border: none;
            border-radius: 0.75rem;
            padding: 0.8rem;
            transition: all 0.2s;
        }

            .btn-notika-primary:hover {
                background-color: #0ea641;
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(19, 236, 91, 0.3);
            }

        .btn-notika-outline {
            background-color: white;
            color: #1a2f23;
            font-weight: 600;
            border: 1px solid #dee2e6;
            border-radius: 0.75rem;
            padding: 0.8rem;
            transition: all 0.2s;
        }

            .btn-notika-outline:hover {
                background-color: #f8f9fa;
                border-color: #c1c9d0;
            }

        .price-box {
            background-color: #e7f3eb;
            border-radius: 1rem;
            padding: 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .installment-btn {
            color: #0ea641;
            font-weight: 600;
            text-decoration: none;
        }

            .installment-btn:hover {
                color: #102216;
                text-decoration: underline;
            }

        /* Taksit tablosu seçili satır rengi (Senin JS kodu kullanıyor) */
        .table-primary {
            background-color: #e7f3eb !important;
            color: #0ea641 !important;
            border-color: #13ec5b !important;
        }
    </style>
</head>
<body>

    <div class="container py-5">
        <div class="row">
            <div class="col-12 col-md-8 col-lg-6 col-xl-5 m-auto">
                <div class="payment-card">

                    <div class="payment-header">
                        <i class="bi bi-credit-card-2-front-fill" style="font-size: 2.5rem; color: #13ec5b;"></i>
                        <h4 class="mt-2 mb-0 fw-bold">Güvenli Ödeme</h4>
                        <p class="text-white-50 mb-0 small mt-1"><i class="bi bi-shield-lock-fill me-1"></i>256-bit SSL ile korunmaktadır</p>
                    </div>

                    <div class="p-4 p-md-5">
                        <form method="post" id="payment-form">
                            <div class="d-flex flex-column gap-4">
                                <input type="hidden" name="Installment" id="installment" value="1">

                                <div>
                                    <label for="cardHolder" class="form-label">Ad Soyad</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0 rounded-start-4 text-muted"><i class="bi bi-person"></i></span>
                                        <input type="text" name="CardHolderName" id="cardHolder" class="form-control custom-input border-start-0 rounded-end-4" placeholder="Kart üzerindeki isim">
                                    </div>
                                </div>

                                <div>
                                    <label for="cardNumber" class="form-label">Kart Numarası</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0 rounded-start-4 text-muted"><i class="bi bi-credit-card"></i></span>
                                        <input type="text" name="CardNumber" id="cardNumber" class="form-control custom-input border-start-0 rounded-end-4" maxlength="19" placeholder="XXXX XXXX XXXX XXXX">
                                    </div>
                                </div>

                                <div class="row g-3">
                                    <div class="col-8">
                                        <label class="form-label">Son Kullanma Tarihi</label>
                                        <div class="d-flex gap-2">
                                            <input type="text" name="ExpireMonth" class="form-control custom-input text-center" maxlength="2" placeholder="Ay">
                                            <span class="fs-4 text-muted">/</span>
                                            <input type="text" name="ExpireYear" class="form-control custom-input text-center" maxlength="2" placeholder="Yıl">
                                        </div>
                                    </div>
                                    <div class="col-4">
                                        <label for="cvc" class="form-label">CVV <i class="bi bi-info-circle ms-1" title="Kartın arkasındaki 3 haneli kod"></i></label>
                                        <input type="text" name="Cvc" id="cvc" class="form-control custom-input text-center" maxlength="4" placeholder="123">
                                    </div>
                                </div>
                            </div>

                            <div class="price-box mt-4">
                                <span class="fw-bold text-muted">Ödenecek Tutar</span>
                                <span class="fs-4 fw-bold" style="color: #0ea641;" id="price-text" data-price="1250">1.250,00 TL</span>
                            </div>

                            <div class="alert alert-danger mt-3 d-none rounded-3 border-0 shadow-sm" role="alert"></div>

                            <div class="d-flex gap-3 mt-4">
                                <button type="button" class="btn-notika-outline w-100" onclick="clearForm()">
                                    <i class="bi bi-trash3 me-1"></i> Temizle
                                </button>
                                <button type="button" class="btn-notika-primary w-100" onclick="payButton(this)">
                                    <i class="bi bi-check-circle me-1"></i> Ödeme Yap
                                </button>
                            </div>
                        </form>

                        <hr class="my-4 text-muted">

                        <div class="text-center">
                            <button type="button" class="btn btn-link installment-btn p-0" onclick="getInstallment(this)">
                                <i class="bi bi-calculator me-1"></i> Taksit Seçeneklerini Gör
                            </button>
                        </div>

                        <div id="installment-table-container" class="mt-3 table-responsive rounded-3"></div>
                    </div>
                </div>

                <div class="text-center mt-4 text-muted small">
                    <i class="bi bi-lock-fill"></i> Güvenli Altyapı Iyzico tarafından sağlanmaktadır.
                </div>

            </div>
        </div>
    </div>

    <script>
        // SCRİPTLERE KESİNLİKLE DOKUNULMADI - BİREBİR AYNI

        async function payButton(button) {
            button.disabled = true;
            button.textContent = "Lütfen Bekleyiniz...";

            const form = document.getElementById("payment-form");
            const formData = new FormData(form);

            const url = "/payment/payment";
            let response;
            try {
                response = await fetch(url, {
                    method: "POST",
                    body: formData
                });

                let result = await response.json();
                if (result.success) {
                    document.open();
                    document.write(result.htmlContent);
                    document.close();
                } else {
                    const alertBox = document.querySelector(".alert");
                    alertBox.textContent = result.message;
                    alertBox.classList.remove("d-none");
                    setTimeout(() => alertBox.classList.add("d-none"), 3000);
                }
            } catch (error) {
                const alertBox = document.querySelector(".alert"); // Hata buradaydı ufak düzelttim (catch içinde alertBox tanımlı değildi)
                alertBox.textContent = "Bir hata oluştu. Lütfen tekrar deneyin.";
                alertBox.classList.remove("d-none");
                setTimeout(() => alertBox.classList.add("d-none"), 3000);
            }

            finally {
                button.disabled = false;
                button.innerHTML = '<i class="bi bi-check-circle me-1"></i> Ödeme Yap';
            }
        }


        async function getInstallment(button) {
            const cardNumberInput = document.getElementById("cardNumber");
            const alertBox = document.querySelector(".alert");
            const container = document.getElementById("installment-table-container");
            const priceElement = document.getElementById("price-text");

            alertBox.classList.add("d-none");
            container.innerHTML = "";

            let cardNumber = cardNumberInput.value.replace(/\s+/g, ""); // boşlukları kaldır
            if (cardNumber.length < 8) {
                alertBox.textContent = "Lütfen en az 8 haneli kart numarası girin.";
                alertBox.classList.remove("d-none");
                setTimeout(() => alertBox.classList.add("d-none"), 3000);
                return;
            }

            const binNumber = cardNumber.substring(0, 8);
            const price = priceElement.getAttribute("data-price");

            button.disabled = true;
            button.textContent = "Lütfen Bekleyiniz...";

            const url = `/payment/getInstallments?binNumber=${binNumber}&price=${price}`;
            let response;
            try {
                response = await fetch(url, {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    }
                });

                let result = await response.json();
                if (result.success) {

                    const prices = result.installmentDetails[0].installmentPrices;

                    let tableHtml = `
                        <table class="table table-hover table-bordered text-center align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Taksit</th>
                                    <th>Taksit Tutarı</th>
                                    <th>Toplam Tutar</th>
                                </tr>
                            </thead>
                            <tbody>
                    `;

                    prices.forEach(item => {
                        tableHtml += `
                            <tr onclick="selectInstallment(this, ${item.totalPrice})" style="cursor:pointer">
                                <td class="fw-bold">${item.installmentNumber}</td>
                                <td>${item.installmentPrice.toFixed(2)} ₺</td>
                                <td class="text-success fw-bold">${item.totalPrice.toFixed(2)} ₺</td>
                            </tr>
                        `;
                    });

                    tableHtml += "</tbody></table>";
                    container.innerHTML = tableHtml;
                } else {
                    alertBox.textContent = result.message || "Taksit bilgileri alınamadı.";
                    alertBox.classList.remove("d-none");
                    setTimeout(() => alertBox.classList.add("d-none"), 3000);
                }
            } catch (error) {
                alertBox.textContent = "Bir hata oluştu. Lütfen tekrar deneyin.";
                alertBox.classList.remove("d-none");
                setTimeout(() => alertBox.classList.add("d-none"), 3000);
            } finally {
                button.disabled = false;
                button.innerHTML = '<i class="bi bi-calculator me-1"></i> Taksit Seçeneklerini Gör';
            }
        }


        // Tablodan taksit seçildiğinde toplam tutarı günceller
        function selectInstallment(row, totalPrice) {
            document.querySelectorAll("#installment-table-container tr").forEach(tr => tr.classList.remove("table-primary"));
            row.classList.add("table-primary");

            const priceElement = document.getElementById("price-text");
            priceElement.setAttribute("data-price", totalPrice);
            priceElement.textContent = `${totalPrice.toLocaleString("tr-TR", { minimumFractionDigits: 2 })} TL`;

            const installmentNumber = row.children[0].textContent.trim(); // Taksit sayısını al
            document.getElementById("installment").value = installmentNumber; // Gizli alana taksit sayısını ata
        }

        function clearForm() {
            const form = document.getElementById("payment-form");
            form.reset();

            // Kart numarasındaki boşluklar, tablo ve seçili taksitleri temizle
            document.getElementById("installment-table-container").innerHTML = "";

            // Fiyatı varsayılana döndür
            const priceElement = document.getElementById("price-text");
            priceElement.setAttribute("data-price", "1250");
            priceElement.textContent = "1.250,00 TL";
        }

    </script>
</body>
</html>