@using Core_IyzicoPaymentSystem.Models
@model ResultModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notika - Ödeme Hatası</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f6f8f6; /* Notika arka plan rengi */
            color: #0d1b12;
            min-height: 100vh;
            display: flex;
            align-items: center;
        }

        .error-card {
            background: #ffffff;
            border-radius: 1.5rem;
            box-shadow: 0 10px 40px rgba(220, 53, 69, 0.08); /* Kırmızımsı hafif gölge */
            border: 1px solid rgba(220, 53, 69, 0.15);
            padding: 3rem 2rem;
            text-align: center;
        }

        .error-icon {
            font-size: 4.5rem;
            color: #dc3545;
            margin-bottom: 1rem;
            line-height: 1;
        }

        .custom-alert {
            background-color: #fff5f5;
            color: #c92a2a;
            border: 1px solid #ffc9c9;
            border-radius: 0.75rem;
            padding: 1rem;
            font-weight: 500;
            font-size: 0.95rem;
        }

        .btn-notika-outline {
            background-color: white;
            color: #1a2f23;
            font-weight: 600;
            border: 1px solid #dee2e6;
            border-radius: 0.75rem;
            padding: 0.8rem 1.5rem;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-block;
        }

            .btn-notika-outline:hover {
                background-color: #f8f9fa;
                border-color: #c1c9d0;
                color: #1a2f23;
                transform: translateY(-2px);
            }
    </style>
</head>
<body>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-5">
                <div class="error-card">

                    <i class="bi bi-x-circle-fill error-icon"></i>

                    <h3 class="fw-bold mb-2">İşlem Başarısız!</h3>
                    <p class="text-muted mb-4 small">Ödeme sırasında bir sorunla karşılaştık.</p>

                    <div class="custom-alert mb-4" role="alert">
                        @Model.Message
                    </div>

                    <a href="/Default/Inbox" class="btn-notika-outline w-100">
                        <i class="bi bi-arrow-left me-1"></i> Ödeme Sayfasına Dön
                    </a>

                </div>
            </div>
        </div>
    </div>

</body>
</html>