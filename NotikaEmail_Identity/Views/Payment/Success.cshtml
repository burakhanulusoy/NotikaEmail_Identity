@using Core_IyzicoPaymentSystem.Models
@model ResultModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notika - Ödeme Başarılı</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f6f8f6; /* Notika arka plan rengi */
            color: #0d1b12;
            min-height: 100vh;
            display: flex;
            align-items: center;
        }

        .success-card {
            background: #ffffff;
            border-radius: 1.5rem;
            box-shadow: 0 10px 40px rgba(19, 236, 91, 0.1); /* Yeşile dönük hafif gölge */
            border: 1px solid rgba(19, 236, 91, 0.2);
            padding: 3rem 2rem;
            text-align: center;
        }

        .success-icon {
            font-size: 4.5rem;
            color: #0ea641;
            margin-bottom: 1rem;
            line-height: 1;
        }

        .custom-alert {
            background-color: #e7f3eb; /* Açık yeşil arka plan */
            color: #0ea641; /* Koyu yeşil metin */
            border: 1px solid #c3e6cb;
            border-radius: 0.75rem;
            padding: 1rem;
            font-weight: 500;
            font-size: 0.95rem;
        }

        .btn-notika-primary {
            background-color: #13ec5b;
            color: #0d1b12;
            font-weight: 700;
            border: none;
            border-radius: 0.75rem;
            padding: 0.8rem 1.5rem;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-block;
        }

            .btn-notika-primary:hover {
                background-color: #0ea641;
                color: white;
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(19, 236, 91, 0.3);
            }
    </style>
</head>
<body>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-5">
                <div class="success-card">

                    <i class="bi bi-check-circle-fill success-icon"></i>

                    <h3 class="fw-bold mb-2">Ödeme Başarılı!</h3>
                    <p class="text-muted mb-4 small">Aramıza hoş geldin, Premium hesabın aktif edildi.</p>

                    <div class="custom-alert mb-4" role="alert">
                        @Model.Message
                    </div>

                    <a href="/Default/Inbox" class="btn-notika-primary w-100">
                        <i class="bi bi-envelope-paper me-1"></i> Gelen Kutusuna Git
                    </a>

                </div>
            </div>
        </div>
    </div>

</body>
</html>